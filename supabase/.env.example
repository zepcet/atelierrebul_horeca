# Copy to `supabase/.env` for `supabase functions serve`.
# Mirror these names in Supabase Dashboard → Edge Functions → Secrets for production.
#
# If the browser shows CORS errors, add your exact site origin (comma-separated for several):
# EXTRA_CORS_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com

# --- Supabase (required for functions that write to DB) ---
SUPABASE_SERVICE_ROLE_KEY=
# SERVICE_ROLE_KEY=

# --- Google Sheets (fetch-leads, fetch-website-leads) ---
# Option A — service account JSON (client_email + private_key). Share sheets with that email.
GOOGLE_SERVICE_ACCOUNT_KEY=
# Option B — OAuth "web" client JSON + refresh token (not the same as service account).
# GOOGLE_OAUTH_CLIENT_JSON={"web":{"client_id":"...","client_secret":"..."}}
# GOOGLE_OAUTH_REFRESH_TOKEN=   # from OAuth Playground with spreadsheets.readonly; add redirect https://developers.google.com/oauthplayground/oauth2/callback to the OAuth client
# Optional overrides:
GOOGLE_SHEET_ID_ADS=
# Multiple ads spreadsheets (comma-separated); overrides single ID when set.
# GOOGLE_SHEET_IDS_ADS=id1,id2
# Optional: exact ads spreadsheet tab name (default: tab named "Leads" any case, else first tab)
GOOGLE_SHEET_TAB_ADS=
GOOGLE_SHEET_ID_WEBSITE=

# --- Meta Marketing API (fetch-meta-campaigns) ---
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_
# Optional: only campaigns whose name contains this substring (default: horeca_obj:lead)
# META_CAMPAIGN_NAME_SUBSTRING=horeca_obj:lead

# --- Other functions (set if you use them) ---
# APOLLO_API_KEY=
# PERPLEXITY_API_KEY=
# FIRECRAWL_API_KEY=
